# ── Sudo abuse (T1548.003) ─────────────────────────────────────────────────
-w /etc/sudoers -p wa -k sudo-config
-w /etc/sudoers.d/ -p wa -k sudo-config
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/sudo -k sudo-exec
-a always,exit -F arch=b32 -S execve -F path=/usr/bin/sudo -k sudo-exec

# ── Sensitive file access (T1003) ──────────────────────────────────────────
-w /etc/shadow -p rwxa -k sensitive_file_access
-w /etc/passwd -p rwxa -k sensitive_file_access

# ── SUID binary abuse (T1548.001) ─────────────────────────────────────────
-a always,exit -F arch=b64 -S execve -F euid=0 -F auid>=1000 -F auid!=4294967295 -k suid_execution
-a always,exit -F arch=b32 -S execve -F euid=0 -F auid>=1000 -F auid!=4294967295 -k suid_execution
# ── Kernel module loading (T1547.006) ─────────────────────────────────────
-w /sbin/insmod   -p x -k module_loading
-w /sbin/rmmod    -p x -k module_loading
-w /sbin/modprobe -p x -k module_loading
-a always,exit -F arch=b64 -S init_module,delete_module,finit_module -k module_loading
-a always,exit -F arch=b32 -S init_module,delete_module,finit_module -k module_loading

# ── Cron tampering (T1053.003) ─────────────────────────────────────────────
-w /etc/crontab               -p wa -k cron_tampering
-w /etc/cron.d/               -p wa -k cron_tampering
-w /etc/cron.daily/           -p wa -k cron_tampering
-w /etc/cron.hourly/          -p wa -k cron_tampering
-w /etc/cron.weekly/          -p wa -k cron_tampering
-w /etc/cron.monthly/         -p wa -k cron_tampering
-w /var/spool/cron/           -p wa -k cron_tampering
-w /var/spool/cron/crontabs/  -p wa -k cron_tampering
